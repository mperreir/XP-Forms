{
  "name": "Ptrans",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "concurrently": "^7.6.0",
    "file-saver": "^2.0.5",
    "i18next": "^26.0.4",
    "jszip": "^3.10.1",
    "react-i18next": "^16.6.6"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd serveur && npm run dev",
    "build": "cd client && npm run build",
    "client": "cd client && npm start",
    "start": "cd serveur && npm start",
    "prod": "npm run build && npm start",
    "install-all": "npm install && cd client && npm install && cd ../serveur && npm install"
  }
}
